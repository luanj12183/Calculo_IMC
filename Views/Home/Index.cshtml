@model Calculo_IMC.Models.ImcViewModel 

@{
    ViewData["Title"] = "Calculadora de IMC";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow border-primary">
        <div class="card-header bg-primary text-white text-center p-3">
            <h3 class="mb-0"><i class="bi bi-calculator"></i> Calculadora de IMC</h3>
            </div>
            <div class="card-body p-4">

            <form asp-action="Index" method="post">
               <div class="mb-3">
                    <label asp-for="Peso" class="form-label fw-bold">Peso (kg)</label>
                    <input asp-for="Peso" class="form-control form-control-lg" type="number" step="0.1" placeholder="Ex: 75,5"/>
                    <span asp-validation-for="Peso" class="text-danger small"></span>
                </div>

           <div class="mb-3">
                <label asp-for="Altura" class="form-label fw-bold">Altura (m)</label>
                <input asp-for="Altura" class="form-control form-control-lg" type="number" step="0.01" placeholder="Ex: 1,75"/>
                <span asp-validation-for="Altura" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw bold mt-2">Calcular o IMC</button>
            </form>

            @if (Model.ResultadoImc > 0)
            {
                <div class="alert @Model.ClasseCss text-center mt-4 border-0 shadow-sm" role="alert">
                    <h4 class="alert-heading fw-bold"> Seu IMC: @Model.ResultadoImc.ToString("F2")</h4>
                    <hr>
                    <p class="mb-0 fs-5">Classificação: <strong>@Model.Classificacao</strong></p>
                </div>
            }
        </div>
    </div>
</div>